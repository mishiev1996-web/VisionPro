# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here

# HTTPS tunnel URL for Mini App (ngrok, Cloudflare Tunnel, etc.)
WEBAPP_URL=https://your-tunnel-id.ngrok.io/mini-app

# CORS: comma-separated allowed origins
ALLOWED_ORIGINS=https://your-tunnel-id.ngrok.io,http://localhost:8000

# API Keys (alternative to Апи/*.txt files)
POLZA_API_KEY=your_polza_api_key
SSTATS_API_KEY=your_sstats_api_key
